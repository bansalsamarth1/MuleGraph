# MuleGraph Environment Configuration

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_STREAMS_STATE_DIR=/tmp/kafka-streams

# PostgreSQL
POSTGRES_URL=jdbc:postgresql://localhost:5432/mulegraph
POSTGRES_USER=muleuser
POSTGRES_PASSWORD=mulepass

# API Security
MULEGRAPH_API_KEY=dev-local-api-key
